<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Email ID</title>
</head>
<body>
  <form method="post" action="/users/<%= user._id %>?_method=PATCH" 
        style="background:#f9f9f9; padding:20px; border:1px solid #ccc; width:300px; margin:auto; text-align:center;">
    
    <label style="display:block; font-weight:bold; margin-bottom:10px; color:brown;">
      Update Email:
    </label>
    
    <input type="email" name="email" value="<%= user.email %>" 
           style="padding:8px; width:90%; margin-bottom:15px; border:1px solid #aaa; border-radius:4px;">
           <input type="text" name="user"value="<%= user.user %>"style="padding:8px; width:90%; margin-bottom:15px; border:1px solid #aaa; border-radius:4px;">
    <input name="password" value="<%= user.password %>"style="padding:8px; width:90%; margin-bottom:15px; border:1px solid #aaa; border-radius:4px;">
<div>
  <input type="checkbox" name="ageCheck" 
    <%= user.ageCheck ? "checked" : "" %> >
  <label>Above 18</label>
</div>

    <button type="submit" 
            style="background:#28a745; color:white; padding:8px 15px; border:none; border-radius:4px; cursor:pointer;">
      Save Changes
    </button>

  </form>  
</body>
</html>