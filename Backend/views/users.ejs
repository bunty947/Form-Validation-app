<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Registered Users</title>
    <link 
   href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" 
  rel="stylesheet">

</head>
<body>
  <h2> Registered Users</h2>
  <div class="table-responsive">
  <table class="table table-striped table-bordered">
<thead class="table-dark">
    <tr>
      <th>#</th>
      <th>Name</th>
      <th>Email</th>
      <th>Gender</th>
      <th>Age-Check</th>
      <th>User-Id</th>
      <th>Action</th>
    </tr>
  </thead>
  <tbody>
    <% for (let i = 0; i < users.length; i++) { %>
      <tr>
        <td><%= i + 1 %></td>
        <td><%= users[i].user %></td>
        <td><%= users[i].email %></td>
        <td><%= users[i].Gender %></td>
        <td><%= users[i].ageCheck %></td>
        <td><%= users[i]._id %></td>
        <td>
          <a href="/users/<%= users[i]._id %>/edit">Edit</a>
          <a href="/users/<%= users[i]._id %>">View</a>
          <form method="POST" 
                action="/users/<%= users[i]._id %>?_method=DELETE" 
                style="display:inline;" 
                onsubmit="return confirmDelete();">
            <button class="btn" type="submit" style="background: none;border: none;color: red; cursor: pointer;">Delete</button>
          </form>
        </td>
      </tr>
    <% } %>
  </tbody></table></div>
  <a href="/" class="btn btn-primary"
 >Back to homepage</a>

<script>
  function confirmDelete(){
    return confirm("Are you sure you want to delete this user permanently?");
  }
</script>
</body>
</html>

